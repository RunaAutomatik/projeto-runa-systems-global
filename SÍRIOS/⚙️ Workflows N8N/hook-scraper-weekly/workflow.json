    {
      "id": "code-yt",
      "name": "Extract YT Hooks",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 620],
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst handle = $('Is Instagram?').last().json.handle;\nconst videos = response.items || [];\nconst results = [];\n\nfor (const video of videos) {\n  const stats = video.statistics || {};\n  const snippet = video.snippet || {};\n  const title = (snippet.title || '').trim();\n\n  if (!title) continue;\n\n  results.push({\n    json: {\n      post_id: String(video.id),\n      post_url: 'https://www.youtube.com/watch?v=' + video.id,\n      platform: 'youtube',\n      source_account: handle,\n      hook_text: title.substring(0, 500),\n      full_caption: (snippet.description || '').substring(0, 1000),\n      format: 'video',\n      likes: parseInt(stats.likeCount || 0),\n      comments: parseInt(stats.commentCount || 0),\n      views: parseInt(stats.viewCount || 0),\n      posted_at: snippet.publishedAt || null\n    }\n  });\n}\n\nreturn results.length > 0 ? results : [{ json: { _skip: true } }];"
      }
    },
