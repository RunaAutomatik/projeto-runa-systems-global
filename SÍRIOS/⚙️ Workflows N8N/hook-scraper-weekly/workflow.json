    {
      "id": "code-ig",
      "name": "Extract IG Hooks",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 300],
      "parameters": {
        "jsCode": "const posts = $input.all();\nconst handle = $('Is Instagram?').first().json.handle;\nconst results = [];\n\nfor (const post of posts) {\n  const p = post.json;\n  const caption = (p.caption || '').trim();\n  const lines = caption.split('\\n').filter(l => l.trim().length > 0);\n  const firstLine = lines[0] || '';\n  const hookText = firstLine.length >= 20 ? firstLine : (caption.split('.')[0] || firstLine);\n\n  if (!hookText || hookText.length < 5) continue;\n\n  let format = 'feed';\n  if (p.type === 'Video') format = 'reel';\n  else if (p.type === 'Sidecar') format = 'carousel';\n\n  results.push({\n    json: {\n      post_id: String(p.id || p.shortCode || ''),\n      post_url: p.url || ('https://www.instagram.com/p/' + (p.shortCode || '')),\n      platform: 'instagram',\n      source_account: handle,\n      hook_text: hookText.substring(0, 500),\n      full_caption: caption.substring(0, 1000),\n      format: format,\n      likes: p.likesCount || 0,\n      comments: p.commentsCount || 0,\n      views: null,\n      posted_at: p.timestamp || null\n    }\n  });\n}\n\nreturn results.length > 0 ? results : [{ json: { _skip: true } }];"
      }
    },
