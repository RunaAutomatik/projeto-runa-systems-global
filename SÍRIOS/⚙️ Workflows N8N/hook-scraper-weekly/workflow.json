    {
      "id": "code-classify",
      "name": "Classify Hook",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2440, 340],
      "parameters": {
        "jsCode": "// Rule-based hook classification — no external API dependency\nconst post = $input.first().json;\nconst text = (post.hook_text || '').toLowerCase();\n\nlet hookType = 'curiosity_gap';\nlet tone = 'emocional';\nlet confidence = 0.55;\n\n// question — ends with ? or starts with interrogative\nif (/\\?/.test(post.hook_text || '')) {\n  hookType = 'question';\n  tone = 'filosofico';\n  confidence = 0.82;\n}\n// attack — confrontational/challenging\nelse if (/\\b(wrong|errado|para de|stop doing|stop using|you're doing it|voce ta errado|erro que|nunca fa|don't do|nao faca|mistake|erro)\\b/.test(text)) {\n  hookType = 'attack';\n  tone = 'provocativo';\n  confidence = 0.76;\n}\n// contradiction — contrarian twist\nelse if (/\\b(but |mas |however|porém|actually|na verdade|contrary|contrário|despite|apesar|isn't|nao e|not what)\\b/.test(text)) {\n  hookType = 'contradiction';\n  tone = 'polarizador';\n  confidence = 0.72;\n}\n// reveal — secret/confession\nelse if (/\\b(secret|segredo|never told|nunca contei|confession|confess|revealing|revelando|truth about|real reason|hidden|escondido)\\b/.test(text)) {\n  hookType = 'reveal';\n  tone = 'emocional';\n  confidence = 0.78;\n}\n// mirror — relatable situation\nelse if (/\\b(you also|voce tambem|you too|ever feel|ever notice|have you|ja sentiu|ja passou|recognize|reconhece|relate|sound familiar)\\b/.test(text)) {\n  hookType = 'mirror';\n  tone = 'emocional';\n  confidence = 0.70;\n}\n// social_proof — results/numbers\nelse if (/\\b(client|cliente|result|resultado|transform|proof|prova|people|pessoas|students|alunos|helped|ajudei|\\$[0-9]|[0-9]+k|[0-9]+m|percent|%)\\b/.test(text)) {\n  hookType = 'social_proof';\n  tone = 'autoritario';\n  confidence = 0.73;\n}\n// manifesto — strong belief/declaration\nelse if (/\\b(never again|nunca mais|i believe|acredito|my truth|minha verdade|promise|prometo|always|sempre|principle|principio|manifesto|vow)\\b/.test(text)) {\n  hookType = 'manifesto';\n  tone = 'filosofico';\n  confidence = 0.65;\n}\n\nreturn [{\n  json: {\n    ...post,\n    hook_type: hookType,\n    tone: tone,\n    classification_confidence: confidence,\n    auto_classified: true\n  }\n}];"
      }
    },
